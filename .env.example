# ── Sanity: подключение контента ──────────────────────────────
# Создайте проект на https://www.sanity.io/ (бесплатно) и подставьте ID.

# Для САЙТА (Vite, читается в браузере). projectId не секретный.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Для АДМИНКИ (Sanity Studio) и скрипта импорта.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Токен с правами на запись — ТОЛЬКО для скрипта импорта (npm run import).
# Создаётся в sanity.io → проект → API → Tokens (роль Editor).
# Секрет! Не коммитить. Файл .env уже в .gitignore.
SANITY_API_TOKEN=
